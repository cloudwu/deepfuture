    "lint:fix": "eslint . --fix",
    "prepare:runtime": "node scripts/prepare-runtime.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
