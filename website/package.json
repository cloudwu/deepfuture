{
  "name": "deepfuture-website",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm run prepare:runtime && vite build",
    "build:pages": "SITE_BASE=/deepfuture/ pnpm run build",
    "dev": "pnpm run prepare:runtime && vite",
    "format": "eslint . --fix",
